USERS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/qrcard_users
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

JWT_PRIVATE_KEY_PATH=app/tokens/jwt-private.pem
JWT_PUBLIC_KEY_PATH=app/tokens/jwt-public.pem
JWT_ALGORITHM=RS256

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_USE_TLS=true
